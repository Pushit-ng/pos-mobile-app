# POS-Choice Mobile — Environment Variables
# Copy this file to .env for local development
# All variables must be prefixed with EXPO_PUBLIC_ to be accessible in the app.

# ── API Base URL ──────────────────────────────────────────────────────────────
# Use your LAN IP in development — localhost does not work on a physical device.
# Find your LAN IP with: ifconfig | grep "inet " (macOS/Linux) or ipconfig (Windows)
#
# Development (LAN):
EXPO_PUBLIC_API_URL=http://192.168.1.100:3003/api/v1
#
# Production (cloud):
# EXPO_PUBLIC_API_URL=https://api.yourstore.com/api/v1

# ── Company ID ────────────────────────────────────────────────────────────────
# MongoDB _id of the company this mobile terminal belongs to.
# Found in: Admin panel → Company Settings, or GET /api/v1/companies/my-company
EXPO_PUBLIC_COMPANY_ID=
